{
  "name": "@atak-reactive/sdk",
  "version": "0.1.6",
  "description": "TypeScript SDK for building React UIs in ATAK plugins",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "~5.8.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/rixau/atak-reactive.git",
    "directory": "sdk"
  }
}
